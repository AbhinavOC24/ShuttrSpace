# ==========================================
# ShuttrSpace Backend Environment Variables
# ==========================================

# Server Configuration
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Ensure your database is created before running the server, schema auto-hydrates!
DATABASE_URL=postgres://username:password@localhost:5432/shuttrspace

# Authentication Secrets
# Generate random secure strings for these (e.g., using `require('crypto').randomBytes(64).toString('hex')`)
JWT_SECRET=your_super_secret_access_key
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key

# ImageKit Storage Configuration
# Get these from your ImageKit.io developer dashboard
IMAGEKIT_PUBLICKEY=your_imagekit_public_key
IMAGEKIT_PRIVATEKEY=your_imagekit_private_key
IMAGEKIT_URLENDPOINT=https://ik.imagekit.io/your_imagekit_id
